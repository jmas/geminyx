{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "app/*": ["app/*"],
      "components/*": ["components/*"],
      "hooks/*": ["hooks/*"],
      "lib/*": ["lib/*"],
      "modules/*": ["modules/*"],
      "screens/*": ["screens/*"],
      "utils/*": ["utils/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
