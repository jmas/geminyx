{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "app/*": ["app/*"],
      "components/*": ["components/*"],
      "db/*": ["data/*"],
      "hooks/*": ["hooks/*"],
      "lib/*": ["lib/*"],
      "modules/*": ["modules/*"],
      "screens/*": ["screens/*"],
      "utils/*": ["utils/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
